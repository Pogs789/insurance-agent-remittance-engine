generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                         String    @id @default(uuid())
  firstName                  String
  middleName                 String
  lastName                   String
  birthDate                  DateTime
  role                       Role      @default(AGENT)
  email                      String    @unique
  passwordHash               String    @unique
  emailConfirmedAt           DateTime?
  verificationToken          String?   @unique
  verificationTokenExpiresAt DateTime?
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt

  refreshTokens  RefreshToken[]
  userFeedback   UserFeedback[]
  insuranceAgent InsuranceAgent?
}

model InsuranceAgent {
  id                         String                     @id @default(uuid())
  userId                     String                     @unique
  insuranceCompany           String
  branchAddress              String
  commissionRate             Float
  monthlyRemittanceHistories MonthlyRemittanceHistory[]
  user                       User                       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model RefreshToken {
  id           String    @id @default(uuid())
  userId       String
  tokenHash    String
  expiresAt    DateTime
  revokedAt    DateTime?
  replacedById String?
  createdAt    DateTime  @default(now())
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model MonthlyRemittanceHistory {
  id             String         @id @default(uuid())
  agentId        String
  amountRemitted Decimal        @db.Decimal(10, 2)
  planholderData Json
  createdAt      DateTime       @default(now())
  updatedAt      DateTime?      @updatedAt
  agent          InsuranceAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)
}

model UserFeedback {
  id                     String  @id @default(uuid())
  userId                 String? //The feedback can be anonymized.
  feedbackTitle          String
  feedbackDescription    String
  recommendToOtherAgents Boolean
  user                   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum Role {
  AGENT
  ADMIN
}

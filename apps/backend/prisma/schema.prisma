generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                         String    @id @default(uuid())
  firstName                  String
  middleName                 String
  lastName                   String
  birthDate                  DateTime
  role                       Role      @default(AGENT)
  email                      String    @unique
  passwordHash               String
  emailConfirmedAt           DateTime?
  verificationToken          String?   @unique
  verificationTokenExpiresAt DateTime?
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt

  refreshTokens  RefreshToken[]
  userFeedback   UserFeedback[]
  insuranceAgent InsuranceAgent?
}

model InsuranceAgent {
  id                         String                     @id @default(uuid())
  userId                     String                     @unique
  insuranceCompanyId         String
  branchAddress              String
  monthlyRemittanceHistories MonthlyRemittanceHistory[]
  user                       User                       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model RefreshToken {
  id           String    @id @default(uuid())
  userId       String
  tokenHash    String
  expiresAt    DateTime
  revokedAt    DateTime?
  replacedById String?
  createdAt    DateTime  @default(now())
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model MonthlyRemittanceHistory {
  id             String         @id @default(uuid())
  agentId        String
  amountRemitted Decimal        @db.Decimal(10, 2)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime?      @updatedAt
  agent          InsuranceAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  planholderData PlanholderData[]

  @@index([agentId])
}

model PlanholderData {
  id                  String           @id @default(uuid())
  monthlyRemittanceId String
  planholderName      String
  insuranceProductId  String
  currentStatus       PlanholderStatus @default(ACTIVE)
  createdAt           DateTime         @default(now())
  updatedAt           DateTime?        @updatedAt

  monthlyRemittaceHistory MonthlyRemittanceHistory @relation(fields: [monthlyRemittanceId], references: [id], onDelete: Cascade)
  insuranceProduct        InsuranceProduct         @relation(fields: [insuranceProductId], references: [id], onDelete: Cascade)
}

model InsuranceProduct {
  id                   String           @id @default(uuid())
  insuranceCompanyId   String
  insuranceProductName String
  productContents      String
  productAmount        Decimal          @db.Decimal(10, 2)
  paymentTerms         String[]
  createdAt            DateTime         @default(now())
  updatedAt            DateTime?        @updatedAt
  planholderData       PlanholderData[]

  insuranceCompany InsuranceCompany @relation(fields: [insuranceCompanyId], references: [id], onDelete: Cascade)
}

model InsuranceCompany {
  id              String    @id @default(uuid())
  companyName     String
  branchAddress   String
  productsOffered String
  commissionRate  Decimal   @db.Decimal(10, 2)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime? @updatedAt

  insuranceProduct InsuranceProduct[]
}

model UserFeedback {
  id                     String  @id @default(uuid())
  userId                 String? //The feedback can be anonymized.
  feedbackTitle          String
  feedbackDescription    String
  recommendToOtherAgents Boolean
  user                   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum Role {
  AGENT
  COMPANYADMIN
  SUPERADMIN
}

enum PlanholderStatus {
  ACTIVE
  INACTIVE
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                         String                     @id @default(uuid())
  email                      String                     @unique
  passwordHash               String                     @unique
  createdAt                  DateTime                   @default(now())
  updatedAt                  DateTime                   @updatedAt
  role                       Role                       @default(AGENT)
  birthDate                  DateTime
  firstName                  String
  insuranceCompany           String
  lastName                   String
  middleName                 String
  commissionRate             Float
  branchAddress              String
  monthlyRemittanceHistories MonthlyRemittanceHistory[]
  refreshTokens              RefreshToken[]
  userFeedback UserFeedback[]
}

//TODO: Add here Insuranceagent model once the tool has many insurance agents using it.

model RefreshToken {
  id           String    @id @default(uuid())
  userId       String
  tokenHash    String
  expiresAt    DateTime
  revokedAt    DateTime?
  replacedById String?
  createdAt    DateTime  @default(now())
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model MonthlyRemittanceHistory {
  id               String           @id @default(uuid())
  userId           String
  amountRemitted   Decimal @db.Decimal(10, 2)
  planholderData   Json
  createdAt        DateTime         @default(now())
  updatedAt        DateTime?        @updatedAt
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserFeedback {
  id String @id @default(uuid())
  userId String? //The feedback can be anonymized.
  feedbackTitle String
  feedbackDescription String
  recommendToOtherAgents Boolean
  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum Role {
  AGENT
  ADMIN
}
{
  "name": "insurance-agent-remittance-engine",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@11.5.0+sha512.dbfcc4f81cf48597afd4bc391ffdf12c11f1a9fb83a395bfa6b0a2d9cc2fd8ffebafdb1ccbd529632153f793904c2615b7f09fe1a345473fd1c35845172a8eb1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:backend": "pnpm --filter backend start:dev",
    "dev:mobile": "cd apps/mobile && flutter run",
    "build": "pnpm --filter shared build && pnpm --filter backend build",
    "build:mobile": "cd apps/mobile && flutter build",
    "test": "pnpm --filter backend test",
    "test:mobile": "cd apps/mobile && flutter test",
    "lint:backend": "pnpm --filter backend lint",
    "lint:mobile": "cd apps/mobile && flutter analyze",
    "format": "prettier --write \"apps/backend/**/*.{ts,json}\" && cd apps/mobile && dart format .",
    "prepare": "husky"
  },
  "lint-staged": {
    "apps/backend/**/*.{ts,js,json}": [
      "prettier --write",
      "eslint --fix"
    ],
    "apps/mobile/**/*.dart": [
      "dart format"
    ],
    "packages/shared/**/*.{ts,json}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^20.2.0",
    "@commitlint/config-conventional": "^20.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0"
  },
  "pnpm": {
    "neverBuiltDependencies": [
      "@nestjs/core"
    ],
    "overrides": {
      "@types/pg": "8.20.0"
    }
  }
}
